{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ZlatanOmerovic/onboardctl/manifest.schema.json",
  "title": "onboardctl manifest",
  "type": "object",
  "required": ["version"],
  "additionalProperties": false,
  "properties": {
    "version":  { "type": "integer", "minimum": 1 },
    "profiles": { "type": "object", "additionalProperties": { "$ref": "#/$defs/profile" } },
    "bundles":  { "type": "object", "additionalProperties": { "$ref": "#/$defs/bundle" } },
    "items":    { "type": "object", "additionalProperties": { "$ref": "#/$defs/item" } },
    "repos":    { "type": "object", "additionalProperties": { "$ref": "#/$defs/repo" } }
  },
  "$defs": {
    "when": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "distro_id":      { "type": "array", "items": { "type": "string" } },
        "distro_family":  { "type": "array", "items": { "type": "string" } },
        "codename":       { "type": "array", "items": { "type": "string" } },
        "desktop":        { "type": "array", "items": { "type": "string" } },
        "arch":           { "type": "array", "items": { "type": "string" } },
        "package_exists": { "type": "array", "items": { "type": "string" } }
      }
    },

    "provider": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "apt",
            "flatpak",
            "binary_release",
            "composer_global",
            "npm_global",
            "config",
            "shell"
          ]
        },
        "package": { "type": "string" },
        "id":      { "type": "string" },
        "repo":    { "type": "string" },
        "source":  { "type": "string" },
        "asset":   { "type": "string" },
        "binary":  { "type": "string" },
        "apply":   { "type": "array", "items": { "type": "string" } },
        "check":   { "type": "string" },
        "when":    { "$ref": "#/$defs/when" },
        "extra":   { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },

    "input_field": {
      "type": "object",
      "required": ["name", "prompt"],
      "additionalProperties": false,
      "properties": {
        "name":    { "type": "string" },
        "prompt":  { "type": "string" },
        "default": { "type": "string" },
        "secret":  { "type": "boolean" }
      }
    },

    "input": {
      "type": "object",
      "required": ["kind", "prompt"],
      "additionalProperties": false,
      "properties": {
        "kind":    { "type": "string", "enum": ["choice", "text", "form", "bool"] },
        "prompt":  { "type": "string" },
        "default": true,
        "choices": { "type": "array", "items": { "type": "string" } },
        "source":  { "type": "string" },
        "fields":  { "type": "array", "items": { "$ref": "#/$defs/input_field" } }
      }
    },

    "item": {
      "type": "object",
      "required": ["name", "providers"],
      "additionalProperties": false,
      "properties": {
        "name":         { "type": "string", "minLength": 1 },
        "description":  { "type": "string" },
        "bundle":       { "type": "string" },
        "providers":    { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/provider" } },
        "when":         { "$ref": "#/$defs/when" },
        "input":        { "$ref": "#/$defs/input" },
        "post_install": { "type": "array", "items": { "type": "string" } },
        "tags":         { "type": "array", "items": { "type": "string" } }
      }
    },

    "bundle": {
      "type": "object",
      "required": ["name", "items"],
      "additionalProperties": false,
      "properties": {
        "name":        { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "items":       { "type": "array", "items": { "type": "string" } }
      }
    },

    "profile": {
      "type": "object",
      "required": ["name", "bundles"],
      "additionalProperties": false,
      "properties": {
        "name":        { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "bundles":     { "type": "array", "items": { "type": "string" } },
        "extends":     { "type": "string" }
      }
    },

    "repo": {
      "type": "object",
      "required": ["kind", "source"],
      "additionalProperties": false,
      "properties": {
        "kind":            { "type": "string", "enum": ["apt"] },
        "keyring":         { "type": "string" },
        "keyring_dearmor": { "type": "boolean" },
        "source":          { "type": "string", "minLength": 1 },
        "when":            { "$ref": "#/$defs/when" }
      }
    }
  }
}
